{
  "name": "ravio---minimalist-premium-e-shop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node generate-snap-urls.mjs && node generate-sitemap.mjs && vite build",
    "postbuild": "react-snap",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu",
      "--no-first-run",
      "--no-zygote",
      "--single-process"
    ],
    "puppeteerExecutablePath": "/usr/bin/google-chrome-stable",
    "skipThirdPartyRequests": true,
    "crawl": true,
    "waitForElement": "#root > *",
    "include": [
      "/",
      "/mehsullar",
      "/haqqimizda",
      "/elaqe",
      "/catdirilma"
    ]
  },
  "dependencies": {
    "@sanity/client": "^7.14.1",
    "@sanity/image-url": "^2.0.3",
    "@vercel/analytics": "^1.5.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.2",
    "sanity": "^5.9.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.0",
    "react-snap": "^1.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}